{
  "name": "fieldsprout",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/api",
    "build": "npm run build --workspace=apps/api",
    "lint": "npm run lint --workspace=apps/api",
    "test": "npm run test --workspace=apps/api",
    "migrate": "npm run migrate --workspace=apps/api",
    "migrate:prod": "npm run migrate:prod --workspace=apps/api"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
