# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://fieldsprout:fieldsprout_dev@localhost:5432/fieldsprout"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production-use-a-long-random-string"
JWT_ACCESS_EXPIRES_IN="24h"
JWT_REFRESH_EXPIRES_IN="7d"

# ── OTP Provider ──────────────────────────────────────────────────────────────
# Set to "fake" for local dev (any phone, code 000000 always valid)
# Set to "twilio" for production
OTP_PROVIDER="fake"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_VERIFY_SERVICE_SID=""

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV="development"

# ── Sentry (optional in dev) ──────────────────────────────────────────────────
SENTRY_DSN=""

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-south-1"
AWS_S3_BUCKET=""

# ── Firebase FCM ──────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_CLIENT_EMAIL=""

# ── Gupshup (WhatsApp) ────────────────────────────────────────────────────────
GUPSHUP_API_KEY=""
GUPSHUP_SOURCE_PHONE=""

# ── MSG91 (SMS) ───────────────────────────────────────────────────────────────
MSG91_AUTH_KEY=""
MSG91_SENDER_ID=""

# ── Stock low alert threshold ─────────────────────────────────────────────────
STOCK_LOW_THRESHOLD=10
